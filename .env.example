# Polymarket (required for LIVE trading only — paper mode needs no keys)
# For a dedicated EOA hot wallet:
#   POLYMARKET_SIGNATURE_TYPE=0
#   POLYMARKET_FUNDER=<same wallet address>
# If you already have persisted API creds, you can set them below;
# otherwise the client will derive them automatically from the private key.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# DingTalk alerts (required for notifications)
DINGTALK_WEBHOOK=
